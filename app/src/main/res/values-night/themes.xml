<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base App Theme -->
    <style name="Theme.BDoner" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <!-- Primary Colors -->
        <item name="colorPrimary">@color/red_primary</item>
        <item name="colorPrimaryDark">@color/red_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/red_accent</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/background_grey</item>
        <item name="colorSurface">@color/white</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/red_dark</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>

        <!-- Text -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Material TextInputLayout -->
        <item name="textInputStyle">@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox</item>
        <item name="materialButtonStyle">@style/BDonerButtonStyle</item>
    </style>

</resources>