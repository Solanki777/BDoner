<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- TOOLBAR -->
    <style name="ToolbarTitleStyle" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textSize">20sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- NAVIGATION DRAWER -->
    <!-- FIX: 15sp -> 16sp for drawer menu items -->
    <style name="DrawerItemTextStyle" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- BUTTONS -->
    <!-- FIX: minHeight 52->56dp, textSize 15->17sp -->
    <style name="BDonerButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">56dp</item>
        <item name="android:textSize">17sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/red_primary</item>
    </style>

    <style name="BDonerButtonOutlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:minHeight">52dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="cornerRadius">12dp</item>
        <item name="strokeColor">@color/red_primary</item>
        <item name="android:textColor">@color/red_primary</item>
    </style>

    <!-- TEXT INPUT -->
    <!-- FIX: added minHeight 60dp for easier touch targets -->
    <style name="BDonerInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/input_border</item>
        <item name="hintTextColor">@color/red_primary</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="android:minHeight">60dp</item>
    </style>
    <style name="BloodBtn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#333333</item>
        <item name="android:textStyle">bold</item>
        <item name="android:background">@drawable/bg_blood_unselected</item>
    </style>

    <!-- CARD -->
    <style name="BDonerCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- SECTION HEADER -->
    <!-- FIX: 18sp -> 20sp -->
    <style name="SectionHeader">
        <item name="android:textSize">20sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <!-- LABEL TEXT (section caps like PERSONAL INFO, LOCATION, SECURITY) -->
    <!-- FIX: was text_secondary grey #6B7280 (invisible on white) -> now red_primary -->
    <!-- FIX: 12sp -> 13sp -->
    <style name="LabelText">
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/red_primary</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:textAllCaps">true</item>
    </style>

</resources>